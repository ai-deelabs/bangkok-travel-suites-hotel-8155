# Beds24 API V2 — TEST PHASE
# Copy to .env (gitignored) for local dev, and set the same keys in Vercel.
# NEVER put real token values in this file — it is committed to git.

# --- Auth (server-side only) ---
# The app uses the ACCESS token (short-lived, ~24h) in the `token:` header.
# To obtain/refresh it, put a REFRESH token (or one-time INVITE_CODE) below and run:
#     bash scripts/beds24-refresh.sh
# That exchanges it for a fresh access token and saves the rotated refresh token.
# ⚠️ Beds24 rotates the refresh token on every exchange — the script handles that.
BEDS24_ACCESS_TOKEN=
BEDS24_INVITE_CODE=

# --- Property + room under test (DeeLabs Hotel → Deluxe Room) ---
BEDS24_PROPERTY_ID=335864
BEDS24_ROOM_ID=694923
BEDS24_REFRESH_TOKEN=
