# Resend email backend for /api/send — set these in the Vercel project
# (Settings → Environment Variables). Do NOT commit real values.

# Resend API key — SERVER-SIDE ONLY. Never expose in HTML or client JS.
RESEND_API_KEY=

# Where booking notifications are sent (the site owner's inbox).
MAIL_TO=

# Verified Resend sender. The domain MUST be verified in Resend
# (add the DNS records Resend provides at your domain's DNS host),
# otherwise sends are rejected.
MAIL_FROM="Bangkok Travel Suites <noreply@bangkoktravelsuiteshotel.com>"

# Optional — subject of the owner notification email.
MAIL_SUBJECT="คำขอจองใหม่ — Bangkok Travel Suites"

# Optional — send a bilingual TH/EN thank-you to the visitor. "true" (default) or "false".
AUTO_REPLY=true
